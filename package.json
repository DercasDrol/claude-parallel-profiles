{
  "name": "claude-parallel-accounts",
  "displayName": "Claude Parallel Accounts",
  "description": "Run a different Claude Code account in each VSCode window simultaneously — capture, switch, and isolate accounts per window.",
  "version": "1.0.5",
  "publisher": "DercasDrol",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DercasDrol/claude-parallel-profiles"
  },
  "license": "MIT",
  "author": {
    "name": "dercasdrol"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["claude", "claude code", "anthropic", "profiles", "profile manager", "accounts", "multi-account"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "extensionKind": ["workspace"],
  "contributes": {
    "commands": [
      {
        "command": "claudeProfiles.switchAccount",
        "title": "Switch Account for This Window",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.switchAccountReload",
        "title": "Switch Account for This Window (Reload)",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.captureAccount",
        "title": "Save Current Account",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.showConversations",
        "title": "Show Live Conversations & Accounts",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.showStatus",
        "title": "Show Account Menu",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.removeProfile",
        "title": "Forget a Saved Account",
        "category": "Claude Accounts"
      }
    ],
    "configuration": {
      "title": "Claude Accounts",
      "properties": {
        "claudeProfiles.sharedHistory": {
          "type": "boolean",
          "default": true,
          "description": "Share conversation history across all accounts (~/.claude-shared): projects, sessions and related state are symlinked from every account's data dir, so a chat continues after switching accounts. Credentials and identity stay per-account. Disable to keep each account's history fully isolated."
        },
        "claudeProfiles.reloadOnSwitch": {
          "type": "boolean",
          "default": false,
          "description": "Reload the whole window after switching accounts. Normally the active conversation switches live on its next message; enable this only if you want a guaranteed full re-read via a window reload."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "vscode:uninstall": "node ./uninstall.js",
    "package": "vsce package",
    "release": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
