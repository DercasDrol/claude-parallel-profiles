{
  "name": "claude-parallel-accounts",
  "displayName": "Claude Parallel Accounts",
  "description": "Companion for the Claude Code VS Code extension: run a different Claude account in each VSCode window simultaneously — capture, switch, and isolate accounts per window.",
  "version": "1.3.1",
  "publisher": "DercasDrol",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DercasDrol/claude-parallel-profiles"
  },
  "bugs": {
    "url": "https://github.com/DercasDrol/claude-parallel-profiles/issues"
  },
  "license": "MIT",
  "author": {
    "name": "dercasdrol"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "profiles",
    "profile manager",
    "accounts",
    "multi-account"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false,
      "description": "Claude accounts live in data directories on the local file system, which virtual workspaces don't have."
    },
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Works in Restricted Mode. The extension never reads or executes workspace content — it only uses the workspace folder path to tell windows apart."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "claudeProfiles.switchAccount",
        "title": "Switch Account for This Window",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.captureAccount",
        "title": "Save Current Account",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.showStatus",
        "title": "Account Quick Action",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.removeProfile",
        "title": "Forget a Saved Account",
        "category": "Claude Accounts"
      },
      {
        "command": "claudeProfiles.showLog",
        "title": "Show Log",
        "category": "Claude Accounts"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "vscode:uninstall": "node ./uninstall.js",
    "package": "vsce package",
    "release": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
