{
  "name": "claude-code-profile-manager",
  "displayName": "Claude Code Profile Manager",
  "description": "Manage separate Claude Code accounts per VSCode profile with isolated data directories",
  "version": "0.1.0",
  "publisher": "tundak",
  "icon": "images/icon.png",
  "author": {
    "name": "Sohan Yadav"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["claude", "claude code", "anthropic", "profiles", "profile manager", "accounts", "multi-account"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeProfiles.setupProfile",
        "title": "Setup Profile",
        "category": "Claude Code Profile Manager"
      },
      {
        "command": "claudeProfiles.loginCurrentProfile",
        "title": "Login to Claude for Current Profile",
        "category": "Claude Code Profile Manager"
      },
      {
        "command": "claudeProfiles.captureAccount",
        "title": "Capture Current Account for This Profile",
        "category": "Claude Code Profile Manager"
      },
      {
        "command": "claudeProfiles.restoreAccount",
        "title": "Restore Saved Account for This Profile",
        "category": "Claude Code Profile Manager"
      },
      {
        "command": "claudeProfiles.showStatus",
        "title": "Show Profile Status",
        "category": "Claude Code Profile Manager"
      },
      {
        "command": "claudeProfiles.removeProfile",
        "title": "Remove Account for Current Profile",
        "category": "Claude Code Profile Manager"
      }
    ],
    "configuration": {
      "title": "Claude Code Profile Manager",
      "properties": {
        "claudeProfiles.autoRestore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically restore the saved account state to ~/.claude.json on profile activation."
        },
        "claudeProfiles.autoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture account data to the profile directory after a successful Claude login."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
